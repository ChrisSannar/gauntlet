{
  "schema_version": 1,
  "run_id": "2026-07-15-tutoring-platform",
  "status": "active",
  "ledger": {
    "remote": "git@github.com:ChrisSannar/gauntlet.git",
    "branch": "master"
  },
  "project": {
    "name": "Single-Tutor Platform",
    "remote": "git@github.com:ChrisSannar/tutoring-platform.git",
    "branch": "main",
    "evidence_mode": "repository-only",
    "deployed_url": null,
    "backlog_path": "projects/tutoring-platform/BOUNDARIES.md"
  },
  "schedule": {
    "timezone": "America/Chicago",
    "start_date": "2026-07-15",
    "end_date": "2026-07-17",
    "cutoff_local_time": "00:00",
    "target_focused_hours": 30,
    "grading_trigger": "learner-before-cutoff"
  },
  "accountability": {
    "rubric_path": "docs/daily-grading-rubric.md",
    "mastery_template_path": "templates/daily-mastery-note.md",
    "overall_rule": "lower-of-delivery-mastery",
    "consequence": {
      "mode": "none",
      "description": "Three-day pilot: retain evidence, grades, and calibration data only.",
      "automatic_execution": false
    },
    "publishing": {
      "mode": "draft-only",
      "channels": ["x"],
      "approval_required": true
    }
  },
  "verification": {
    "commands": [
      {
        "id": "python-dependencies",
        "command": ["env", "UV_CACHE_DIR=/tmp/tutoring-platform-uv-cache", "uv", "sync", "--project", "backend", "--locked", "--offline", "--group", "test"],
        "timeout_seconds": 300,
        "required": true,
        "infrastructure": true
      },
      {
        "id": "javascript-dependencies",
        "command": ["env", "BUN_INSTALL_CACHE_DIR=/home/chrissannar/.cache/gauntlet/bun", "bun", "install", "--frozen-lockfile", "--offline"],
        "timeout_seconds": 300,
        "required": true,
        "infrastructure": true
      },
      {
        "id": "frontend-typecheck",
        "command": ["bun", "run", "--cwd", "frontend", "build"],
        "timeout_seconds": 120,
        "required": true
      },
      {
        "id": "frontend-unit",
        "command": ["bun", "run", "--cwd", "frontend", "test"],
        "timeout_seconds": 120,
        "required": true
      },
      {
        "id": "backend-tests",
        "command": ["env", "UV_CACHE_DIR=/tmp/tutoring-platform-uv-cache", "uv", "run", "--project", "backend", "--offline", "--group", "test", "pytest", "backend/tests"],
        "timeout_seconds": 180,
        "required": true
      },
      {
        "id": "frontend-build",
        "command": ["bun", "run", "build"],
        "timeout_seconds": 180,
        "required": true
      },
      {
        "id": "critical-path-e2e",
        "command": ["bun", "run", "test:e2e"],
        "timeout_seconds": 300,
        "required": true
      }
    ],
    "browser": {
      "enabled": false,
      "adapter": null,
      "required": false
    }
  },
  "adapters": {
    "grader": {
      "command": ["/usr/bin/env", "python", "/home/chrissannar/Practice/gauntlet/controller/openrouter_adapter.py"],
      "timeout_seconds": 180
    },
    "planner": {
      "command": ["/usr/bin/env", "python", "/home/chrissannar/Practice/gauntlet/controller/openrouter_adapter.py"],
      "timeout_seconds": 180
    },
    "appeal_judge": {
      "command": ["/usr/bin/env", "python", "/home/chrissannar/Practice/gauntlet/controller/openrouter_adapter.py"],
      "timeout_seconds": 180
    }
  }
}
